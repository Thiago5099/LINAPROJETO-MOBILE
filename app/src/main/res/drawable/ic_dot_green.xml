<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="32dp"
    android:height="32dp"
    android:viewportWidth="32"
    android:viewportHeight="32">

    <!-- Círculo com gradiente azul ciano → verde teal -->
    <path
        android:pathData="M16,2A14,14 0,1 1,2 16,14,14 0,0 1,16 2Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="2"
                android:startY="2"
                android:endX="30"
                android:endY="30">
                <item android:offset="0" android:color="#00BCD4"/>
                <item android:offset="1" android:color="#1DE9B6"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Chevron esquerda -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M19,10.5 C19,10.5 13,16 13,16 C13,16 19,21.5 19,21.5"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillAlpha="0"/>

</vector>