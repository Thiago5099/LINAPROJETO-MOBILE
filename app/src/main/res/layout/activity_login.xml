<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!-- Logo + título -->
    <LinearLayout
        android:id="@+id/logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/imageViewLogo"
            android:layout_width="74dp"
            android:layout_height="64dp"
            android:contentDescription="Logo Lina"
            android:src="@drawable/ic_login_logo"/>

        <TextView
            android:id="@+id/textViewLina"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lina"
            android:textColor="#0078FF"
            android:textSize="48sp"/>
    </LinearLayout>

    <!-- Slogan -->
    <TextView
        android:id="@+id/textViewSlogan"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Planejamento alimentar para uma vida mais saudável"
        android:textAlignment="center"
        android:textSize="16sp"
        android:textColor="#475569"
        app:layout_constraintTop_toBottomOf="@id/logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- Card principal -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardForm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        android:backgroundTint="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/textViewSlogan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Abas -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:backgroundTint="#CBCBCB"
                app:cardCornerRadius="9999dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/buttonEntrarTab"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:backgroundTint="#FFFFFF"
                        android:text="Entrar"
                        android:textStyle="bold"
                        android:textColor="#0F172A"
                        android:textSize="16sp"
                        android:layout_marginLeft="4dp"
                        />

                    <Button
                        android:id="@+id/buttonRegistrarTab"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:backgroundTint="#CBCBCB"
                        android:text="Registrar"
                        android:textColor="#0F172A"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginRight= "4dp"/>
                        />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Layout de Login -->
            <LinearLayout
                android:id="@+id/layoutLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible"
                android:layout_marginTop="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="#475569"
                    android:textSize="14sp"/>

                <EditText
                    android:id="@+id/editTextLoginEmail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="seu@email.com"
                    android:inputType="textEmailAddress"
                    android:padding="12dp"
                    android:textColor="#0F172A"
                    android:textSize="16sp"
                    android:background="@drawable/bg_login_edit_spinner"
                    android:drawableStart="@drawable/ic_login_email"
                    android:drawablePadding="8dp"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Senha"
                    android:textColor="#475569"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"/>

                <EditText
                    android:id="@+id/editTextLoginSenha"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:padding="12dp"
                    android:textColor="#0F172A"
                    android:textSize="16sp"
                    android:background="@drawable/bg_login_edit_spinner"
                    android:drawableStart="@drawable/ic_login_senha"
                    android:drawablePadding="8dp"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/textViewEsqueciSenha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Esqueci minha senha"
                    android:textColor="#0078FF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <Button
                    android:id="@+id/buttonEntrar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Entrar"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:backgroundTint="#0078FF"
                    android:layout_marginTop="16dp"/>
            </LinearLayout>

            <!-- Layout de Cadastro -->
            <LinearLayout
                android:id="@+id/layoutCadastro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nome Completo"
                    android:textColor="#475569"
                    android:textSize="14sp"/>

                <EditText
                    android:id="@+id/editTextNome"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Maria Silva"
                    android:padding="12dp"
                    android:textColor="#0F172A"
                    android:textSize="16sp"
                    android:background="@drawable/bg_login_edit_spinner"
                    android:drawableStart="@drawable/ic_login_nome"
                    android:drawablePadding="8dp"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="#475569"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"/>

                <EditText
                    android:id="@+id/editTextCadastroEmail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="seu@email.com"
                    android:inputType="textEmailAddress"
                    android:padding="12dp"
                    android:textColor="#0F172A"
                    android:textSize="16sp"
                    android:background="@drawable/bg_login_edit_spinner"
                    android:drawableStart="@drawable/ic_login_email"
                    android:drawablePadding="8dp"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Senha"
                    android:textColor="#475569"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"/>

                <EditText
                    android:id="@+id/editTextCadastroSenha"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:padding="12dp"
                    android:textColor="#0F172A"
                    android:textSize="16sp"
                    android:background="@drawable/bg_login_edit_spinner"
                    android:drawableStart="@drawable/ic_login_senha"
                    android:drawablePadding="8dp"
                    android:layout_marginTop="4dp"/>

                <Button
                    android:id="@+id/buttonFotoPerfil"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Foto de Perfil"
                    android:textStyle="bold"
                    android:textColor="#0F172A"
                    android:textSize="16sp"
                    android:backgroundTint="#D9D9D9"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gênero"
                    android:textColor="#475569"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"/>

                <Spinner
                    android:id="@+id/spinnerGenero"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_login_edit_spinner"
                    android:padding="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Restrições Alimentares"
                    android:textColor="#475569"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"/>

                <Spinner
                    android:id="@+id/spinnerRestricoes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_login_edit_spinner"
                    android:padding="8dp"/>

                <Button
                    android:id="@+id/buttonRegistrar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Criar Conta"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:backgroundTint="#0078FF"
                    android:layout_marginTop="16dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <!-- Card de Esqueci a Senha -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardEsqueciSenha"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        android:backgroundTint="#FFFFFF"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/textViewSlogan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recuperar Senha"
                android:textColor="#475569"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Digite seu email para redefinir a senha"
                android:textColor="#475569"
                android:textSize="14sp"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/editTextRecuperarEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="seu@email.com"
                android:inputType="textEmailAddress"
                android:textColor="#0F172A"
                android:textSize="16sp"
                android:background="@drawable/bg_login_edit_spinner"
                android:drawableStart="@drawable/ic_login_email"
                android:drawablePadding="8dp"
                android:layout_marginTop="4dp"/>

            <Button
                android:id="@+id/buttonRecuperarSenha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enviar link de recuperação"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:backgroundTint="#0078FF"
                android:layout_marginTop="16dp"/>

            <!-- Botão voltar -->
            <Button
                android:id="@+id/buttonVoltarLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Voltar"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:backgroundTint="#475569"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>


    <!-- Rodapé -->
    <TextView
        android:id="@+id/textViewRodape"
        android:layout_width="363dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="56dp"
        android:text="Organize suas refeições e cuide da sua saúde com Lina"
        android:textAlignment="center"
        android:textColor="#717182"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cardForm"
        app:layout_constraintVertical_bias="0.333" />

</androidx.constraintlayout.widget.ConstraintLayout>
