<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!-- Logo -->
    <TextView
        android:id="@+id/textViewLina"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lina"
        android:textColor="#0078FF"
        android:textSize="48sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Slogan -->
    <TextView
        android:id="@+id/textViewSlogan"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Planejamento alimentar para uma vida mais saudável"
        android:textAlignment="center"
        android:textSize="16sp"
        android:textColor="#475569"
        app:layout_constraintTop_toBottomOf="@id/textViewLina"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- Card principal -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardForm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        android:backgroundTint="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/textViewSlogan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Abas -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:backgroundTint="#CBCBCB"
                app:cardCornerRadius="9999dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/buttonEntrarTab"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:backgroundTint="#FFFFFF"
                        android:text="Entrar"
                        android:textStyle="bold"
                        android:textColor="#0F172A"
                        android:textSize="16sp"/>

                    <Button
                        android:id="@+id/buttonRegistrarTab"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:backgroundTint="#CBCBCB"
                        android:text="Registrar"
                        android:textColor="#0F172A"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Layout de Login -->
            <LinearLayout
                android:id="@+id/layoutLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="#475569"
                    android:textSize="14sp"/>

                <EditText
                    android:id="@+id/editTextLoginEmail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Maria Silva"
                    android:inputType="textEmailAddress"
                    android:padding="12dp"
                    android:textColor="#0F172A"
                    android:textSize="16sp"
                    android:background="#f3f3f5"
                    android:drawableStart="@android:drawable/ic_dialog_email"
                    android:drawablePadding="8dp"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Senha"
                    android:textColor="#475569"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"/>

                <EditText
                    android:id="@+id/editTextLoginSenha"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:padding="12dp"
                    android:textColor="#0F172A"
                    android:textSize="16sp"
                    android:background="#f3f3f5"
                    android:drawableStart="@android:drawable/ic_lock_lock"
                    android:drawablePadding="8dp"
                    android:layout_marginTop="4dp"/>

                <Button
                    android:id="@+id/buttonEntrar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Entrar"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:backgroundTint="#0078FF"
                    android:layout_marginTop="16dp"/>
            </LinearLayout>

            <!-- Layout de Cadastro -->
            <LinearLayout
                android:id="@+id/layoutCadastro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nome Completo"
                    android:textColor="#475569"
                    android:textSize="14sp"/>

                <EditText
                    android:id="@+id/editTextNome"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Maria Silva"
                    android:padding="12dp"
                    android:textColor="#0F172A"
                    android:textSize="16sp"
                    android:background="#f3f3f5"
                    android:drawableStart="@android:drawable/ic_menu_edit"
                    android:drawablePadding="8dp"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="#475569"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"/>

                <EditText
                    android:id="@+id/editTextCadastroEmail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="seu@email.com"
                    android:inputType="textEmailAddress"
                    android:padding="12dp"
                    android:textColor="#0F172A"
                    android:textSize="16sp"
                    android:background="#f3f3f5"
                    android:drawableStart="@android:drawable/ic_dialog_email"
                    android:drawablePadding="8dp"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Senha"
                    android:textColor="#475569"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"/>

                <EditText
                    android:id="@+id/editTextCadastroSenha"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:padding="12dp"
                    android:textColor="#0F172A"
                    android:textSize="16sp"
                    android:background="#f3f3f5"
                    android:drawableStart="@android:drawable/ic_lock_lock"
                    android:drawablePadding="8dp"
                    android:layout_marginTop="4dp"/>

                <CheckBox
                    android:id="@+id/checkBoxDiabetico"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Diabético(a)"
                    android:textColor="#475569"
                    android:layout_marginTop="8dp"/>

                <Button
                    android:id="@+id/buttonRegistrar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Criar Conta"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:backgroundTint="#0078FF"
                    android:layout_marginTop="16dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Rodapé -->
    <TextView
        android:id="@+id/textViewRodape"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Organize suas refeições e cuide da sua saúde com Lina"
        android:textAlignment="center"
        android:textSize="14sp"
        android:textColor="#717182"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
