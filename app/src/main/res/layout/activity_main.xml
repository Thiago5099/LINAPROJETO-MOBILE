<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Título -->
    <TextView
        android:id="@+id/titulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Monte seu Cardápio Semanal"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#333333"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="16dp"/>

    <!-- Chips (dias da semana) -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupDias"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:chipSpacing="8dp"
        app:layout_constraintTop_toBottomOf="@id/titulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- SEGUNDA -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipSeg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SEGUNDA"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="#E0E0E0"/>

        <!-- TERÇA -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipTer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TERÇA"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="#E0E0E0"/>

        <!-- QUARTA -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipQua"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QUARTA"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="#E0E0E0"/>

        <!-- QUINTA -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipQui"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QUINTA"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="#E0E0E0"/>

        <!-- SEXTA -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipSex"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SEXTA"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="#E0E0E0"/>

        <!-- SÁBADO -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipSab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SÁBADO"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="#E0E0E0"/>

        <!-- DOMINGO -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipDom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DOMINGO"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="#E0E0E0"/>

    </com.google.android.material.chip.ChipGroup>

    <!-- Lista de refeições -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerRefeicoes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/chipGroupDias"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>