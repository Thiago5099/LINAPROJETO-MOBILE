<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cardápio Atual"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="12dp" />

            <!-- Card atual com fundo verde claro -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAtual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#E8F8F3">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="☀ Café da Manhã"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvNomeAtual"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Omelete com Vegetais"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/tvTempoAtual"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⏱ 15 min"
                            android:textSize="12sp"
                            android:textColor="#888888"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:id="@+id/tvCaloriasAtual"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚡ 280 kcal"
                            android:textSize="12sp"
                            android:textColor="#888888" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnVerReceitaAtual"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Ver Receita"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#1D9E75"
                        app:cornerRadius="8dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mudar Cardápio"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvOpcoes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnContinuar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="16dp"
        android:text="Continuar com a mesma refeição"
        android:textColor="@android:color/white"
        android:backgroundTint="#378ADD"
        app:cornerRadius="12dp" />

</LinearLayout>