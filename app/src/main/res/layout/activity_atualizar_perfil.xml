<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#F5F5F5">

    <!-- Logo -->
    <LinearLayout
        android:id="@+id/logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/imageViewLogo"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_login_logo"
            android:contentDescription="Logo Lina"/>

        <TextView
            android:id="@+id/textViewLina"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Lina"
            android:textColor="#0078FF"
            android:textSize="42sp"/>
    </LinearLayout>

    <!-- Slogan -->
    <TextView
        android:id="@+id/textViewSlogan"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Planejamento alimentar para uma vida mais saudável"
        android:textAlignment="center"
        android:textColor="#1E1E1E"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardCadastro"
        android:layout_width="366dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:backgroundTint="#FFFFFF"
        app:cardCornerRadius="18dp"
        app:cardElevation="3dp"
        app:layout_constraintTop_toBottomOf="@id/textViewSlogan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Atualizar Perfil -->
            <TextView
                android:id="@+id/textViewAtualizar"
                android:layout_width="match_parent"
                android:layout_height="49dp"
                android:background="@drawable/bg_atulizar_btn"
                android:gravity="center"
                android:text="Atualizar Perfil"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <!-- Nome -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Nome Completo"
                android:textColor="#1E1E1E"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/editTextNome"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_login_edit_spinner"
                android:drawableStart="@drawable/ic_login_nome"
                android:drawablePadding="8dp"
                android:hint="Maria Silva"
                android:padding="12dp"
                android:textSize="14sp"/>

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Email"
                android:textColor="#1E1E1E"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/editTextCadastroEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_login_edit_spinner"
                android:drawableStart="@drawable/ic_login_email"
                android:drawablePadding="8dp"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:padding="12dp"
                android:textSize="14sp"/>

            <!-- Senha -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Senha"
                android:textColor="#1E1E1E"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/editTextCadastroSenha"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_login_edit_spinner"
                android:drawableStart="@drawable/ic_login_senha"
                android:drawablePadding="8dp"
                android:hint="••••••••"
                android:inputType="textPassword"
                android:padding="12dp"
                android:textSize="14sp"/>

            <!-- Foto -->
            <Button
                android:id="@+id/buttonFotoPerfil"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#D9D9D9"
                android:text="Foto de Perfil"
                android:textColor="#000000"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnCancelarAssinatura"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#D9D9D9"
                android:text="Cancelar Assinatura"
                android:textColor="#000000"
                android:textStyle="bold"/>

            <!-- Gênero -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Gênero"
                android:textColor="#1E1E1E"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <Spinner
                android:id="@+id/spinnerGenero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_login_edit_spinner"
                android:entries="@array/opcoes_genero"
                android:padding="8dp"/>

            <!-- Restrições -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Restrições Alimentares"
                android:textColor="#1E1E1E"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <Spinner
                android:id="@+id/spinnerRestricoes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_login_edit_spinner"
                android:entries="@array/opcoes_restricoes_labels"
                android:padding="8dp"/>

            <!-- Botão -->
            <Button
                android:id="@+id/buttonRegistrar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="18dp"
                android:backgroundTint="#0078FF"
                android:text="Entrar"
                android:textColor="@android:color/white"
                android:textStyle="bold"/>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Rodapé -->
    <TextView
        android:id="@+id/textViewRodape"
        android:layout_width="366dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Organize suas refeições e cuide da sua saúde com Lina"
        android:textAlignment="center"
        android:textColor="#4F4F4F"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/cardCadastro"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>