<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:id="@+id/main"
    android:layout_height="match_parent"
    android:background="#F5F5F5">


    <!-- TÍTULO CENTRAL -->
    <TextView
        android:id="@+id/titulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Monte seu Cardápio Semanal"
        android:textColor="#222"
        android:layout_marginLeft="50dp"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- SUBTÍTULO CENTRAL -->


    <ImageButton
        android:id="@+id/buttonVoltarReceita"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        android:adjustViewBounds="true"
        android:background="@drawable/bg_btn_voltar_circulo"
        android:backgroundTint="#119488"
        android:padding="12dp"
        android:scaleType="centerInside"
        android:src="@drawable/bg_btn_voltar_seta"
        app:layout_constraintBottom_toBottomOf="@id/titulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/titulo"
        app:layout_constraintVertical_bias="0.826" />

    <TextView
        android:id="@+id/subtitulo"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:text="Selecione uma opção em cada período (café da manhã, almoço, lanche da tarde e jantar)"
        android:textSize="13sp"
        android:textColor="#777"
        android:layout_marginLeft="50dp"
        android:gravity="center"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/titulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- LINHA DIVISÓRIA -->
    <View
        android:id="@+id/linha"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/subtitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- DIAS (SCROLL) -->
    <HorizontalScrollView
        android:id="@+id/scrollDias"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/linha"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupDias"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:chipSpacing="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSeg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Segunda"
                style="@style/Widget.MaterialComponents.Chip.Choice"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Terça"
                style="@style/Widget.MaterialComponents.Chip.Choice"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipQua"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quarta"
                style="@style/Widget.MaterialComponents.Chip.Choice"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipQui"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quinta"
                style="@style/Widget.MaterialComponents.Chip.Choice"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSex"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sexta"
                style="@style/Widget.MaterialComponents.Chip.Choice"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sábado"
                style="@style/Widget.MaterialComponents.Chip.Choice"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Domingo"
                style="@style/Widget.MaterialComponents.Chip.Choice"/>

        </com.google.android.material.chip.ChipGroup>

    </HorizontalScrollView>

    <!-- LINHA COM DIA + CONTADOR -->
    <TextView
        android:id="@+id/txtDia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Segunda"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#222"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/scrollDias"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/txtContador"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0/4 períodos"
        android:textColor="#2E7D32"
        android:textStyle="bold"
        android:textSize="12sp"
        android:background="#E8F5E9"
        android:padding="6dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="@id/txtDia"
        app:layout_constraintBottom_toBottomOf="@id/txtDia"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SALVAR SEMANA -->

    <!-- LISTA -->

    <Button
        android:id="@+id/btnSalvarCardapio"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#1976D2"
        android:text="Salvar cardápio da semana"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerRefeicoes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtDia"
        app:layout_constraintBottom_toTopOf="@id/btnSalvarCardapio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- BOTÃO -->

</androidx.constraintlayout.widget.ConstraintLayout>