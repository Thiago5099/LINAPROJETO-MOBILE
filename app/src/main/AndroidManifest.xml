            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Criar Cardápio -->
        <activity
            android:name=".feture.CriarCardapio.CriarCardapioMainActivity"
