                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Compras -->
        <activity
            android:name=".feture.Compras.models.ComprasMainActivity"
            android:exported="true"
            tools:ignore="DuplicateActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Nutricionistas -->
        <activity
            android:name=".feture.Nutricionistas.NutricionistaMainActivity"
            android:exported="true"
