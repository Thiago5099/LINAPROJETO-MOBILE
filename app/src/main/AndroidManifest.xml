        android:theme="@style/Theme.Lina">

        <!-- Principal -->
        <activity
            android:name=".feture.Login.LoginCadastro"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Cardápio -->
        <activity
            android:name=".feture.Cardapio.CardapioMainActivity"
